msgid "Obiettivi del package"
msgstr "Package goals"

#: ../../source/index.md:20
msgid "offrire API piccole e leggibili"
msgstr "offer small, readable APIs"

#: ../../source/index.md:21
msgid "validare subito gli input problematici"
msgstr "validate problematic inputs early"

#: ../../source/index.md:22
msgid "produrre errori chiari in notebook e script didattici"
msgstr "produce clear errors in notebooks and teaching scripts"

