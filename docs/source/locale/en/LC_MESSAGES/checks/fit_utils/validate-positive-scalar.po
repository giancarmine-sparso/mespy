#: ../../source/checks/fit_utils/validate-positive-scalar.md:1
msgid "_validate_positive_scalar"
msgstr "_validate_positive_scalar"

#: ../../source/checks/fit_utils/validate-positive-scalar.md:3
msgid "Firma"
msgstr "Signature"

#: ../../source/checks/fit_utils/validate-positive-scalar.md:9
msgid "Che problema risolve"
msgstr "What problem it solves"

#: ../../source/checks/fit_utils/validate-positive-scalar.md:11
msgid "Controlla che un parametro scalare sia numerico, finito e strettamente positivo."
msgstr "Checks that a scalar parameter is numeric, finite, and strictly positive."

#: ../../source/checks/fit_utils/validate-positive-scalar.md:13
msgid "Contratto sugli input"
msgstr "Input contract"

#: ../../source/checks/fit_utils/validate-positive-scalar.md:15
msgid "`value` deve essere interpretabile come numero finito."
msgstr "`value` must be interpretable as a finite number."

#: ../../source/checks/fit_utils/validate-positive-scalar.md:16
msgid "`value` deve essere maggiore di zero."
msgstr "`value` must be greater than zero."

#: ../../source/checks/fit_utils/validate-positive-scalar.md:18
msgid "Dove viene usata"
msgstr "Where it is used"

#: ../../source/checks/fit_utils/validate-positive-scalar.md:20
msgid "in [`lin_fit`](../../moduli/fit_utils/lin-fit.md) per validare `tol`"
msgstr "in [`lin_fit`](../../moduli/fit_utils/lin-fit.md) to validate `tol`"

#: ../../source/checks/fit_utils/validate-positive-scalar.md:22
msgid "Come fallisce"
msgstr "Failure modes"

#: ../../source/checks/fit_utils/validate-positive-scalar.md:24
msgid "`ValueError` se `value` non e finito"
msgstr "`ValueError` if `value` is not finite"

#: ../../source/checks/fit_utils/validate-positive-scalar.md:25
msgid "`ValueError` se `value <= 0`"
msgstr "`ValueError` if `value <= 0`"

#: ../../source/checks/fit_utils/validate-positive-scalar.md:27
msgid "Perche resta privata"
msgstr "Why it stays private"

#: ../../source/checks/fit_utils/validate-positive-scalar.md:29
msgid ""
"Serve come piccolo guard rail locale per i parametri numerici del fit, non come utilita generale "
"del package."
msgstr ""
"It serves as a small local guard rail for numeric fit parameters, not as a general package "
"utility."

